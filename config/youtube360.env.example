# Configuracion principal para youtube360_next

# Modo operativo: test | production
PIPELINE_MODE=test

# Modo de salida:
# dual   -> YouTube + grabacion local
# stream -> solo YouTube
# record -> solo grabacion local
OUTPUT_MODE=dual

# URLs RTSP de entrada
URL_RTSP_CAM1="rtsp://usuario:password@CAM1_IP:554/Streaming/channels/101"
URL_RTSP_CAM2="rtsp://usuario:password@CAM2_IP:554/Streaming/channels/101"

# Destino YouTube
YOUTUBE_RTMP_URL="rtmps://a.rtmps.youtube.com/live2"
STREAM_KEY="REEMPLAZAR_CON_TU_CLAVE"

# Grabacion local
RECORDINGS_ENABLED=true
RECORDINGS_PATH="./runtime/recordings"
SEGMENT_TIME=60
SEGMENT_FORMAT="mp4"
RECORDINGS_KEEP_DAYS=7

# Parametros de salida conservadores
FPS=25
OUTPUT_WIDTH=2160
OUTPUT_HEIGHT=1080
BITRATE_VIDEO="8000k"
MAXRATE_VIDEO="8000k"
MINRATE_VIDEO="8000k"
BUFSIZE_VIDEO="16000k"
BITRATE_AUDIO="128k"
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNEL_LAYOUT=stereo
PIX_FMT="yuv420p"
GOP=50

# Encoder
VIDEO_CODEC="libx264"
X264_PRESET="superfast"
X264_PROFILE="high"
X264_LEVEL="4.2"
X264_CRF=22
X264_BFRAMES=2
X264_REF=1

# Ajustes RTSP
RTSP_TRANSPORT="tcp"
RTSP_STIMEOUT_US=5000000
THREAD_QUEUE_SIZE=1024
INPUT_ANALYZE_DURATION_US=2000000
INPUT_PROBE_SIZE=2000000

# Ajustes de crop heredados de las pruebas antiguas
# Formato: ancho:alto:x:y
CAM1_CROP="1014:1014:453:33"
CAM2_CROP="1014:1014:453:33"
AUTO_ADJUST_CROP=false
CALIBRATION_DRAW_CIRCLE=true
CALIBRATION_DRAW_GRID=true
CALIBRATION_CIRCLE_RADIUS_PERCENT=48
CALIBRATION_LINE_THICKNESS=4
CALIBRATION_FONT_SIZE=36
CALIBRATION_GRID_DIVISIONS=6
CALIBRATION_CENTER_MARK_SIZE=18
CAM1_FISHEYE_CENTER_OFFSET_X=0
CAM1_FISHEYE_CENTER_OFFSET_Y=0
CAM2_FISHEYE_CENTER_OFFSET_X=0
CAM2_FISHEYE_CENTER_OFFSET_Y=0
CALIBRATION_EQUIRECT_SEAM_GUIDE=true
CALIBRATION_SWEEP_DURATION_SECONDS=5
CALIBRATION_SWEEP_X_OFFSETS="-20,0,20"
CALIBRATION_SWEEP_Y_OFFSETS="-20,0,20"
CALIBRATION_SWEEP_FOVS="180,185,190"
CAM1_PRE_ROTATE=0
CAM2_PRE_ROTATE=0
CAM1_HFLIP=false
CAM2_HFLIP=false
CAM1_VFLIP=false
CAM2_VFLIP=false

# Transformacion 360
V360_INPUT="dfisheye"
V360_OUTPUT="equirect"
V360_IH_FOV=200
V360_IV_FOV=200

# Reintentos / watchdog
RESTART_DELAY_SECONDS=5
STALL_TIMEOUT_SECONDS=45
HEALTHCHECK_INTERVAL_SECONDS=15
STARTUP_GRACE_SECONDS=75
RECORDING_STALL_TIMEOUT_SECONDS=90
# Reinicio programado del ffmpeg. 0 desactiva esta funcion.
MAX_FFMPEG_UPTIME_SECONDS=3600
MAX_RESTARTS=0
STRICT_RTMP_WATCHDOG=true
STRICT_RTMP_ERROR_WINDOW_SECONDS=120
STRICT_RTMP_ERROR_THRESHOLD=1
STRICT_RTSP_WATCHDOG=true
STRICT_RTSP_ERROR_WINDOW_SECONDS=60
STRICT_RTSP_ERROR_THRESHOLD=5
RESTART_LOOP_WINDOW_SECONDS=300
RESTART_LOOP_THRESHOLD=6

# Pruebas locales
LOCAL_TEST_DURATION_SECONDS=30
SNAPSHOT_TIMEOUT_SECONDS=15

# Rutas
RUNTIME_DIR="./runtime"
ARTIFACTS_DIR="./artifacts"
LOGS_CURRENT_DIR="./runtime/logs/current"
LOGS_ARCHIVE_DIR="./runtime/logs/archive"
OPS_LOG_DIR="./runtime/logs/current/ops"
VALIDATION_LOG_DIR="./runtime/logs/current/validation"
CALIBRATION_LOG_DIR="./runtime/logs/current/calibration"
DIAGNOSTIC_LOG_DIR="./runtime/logs/current/diagnostics"
TEST_LOG_DIR="./runtime/logs/current/test"
STATE_DIR="./runtime/state"
RUNTIME_TMP_DIR="./runtime/tmp"
ARTIFACTS_CALIBRATION_DIR="./artifacts/calibration"
ARTIFACTS_DIAGNOSTICS_DIR="./artifacts/diagnostics"
ARTIFACTS_TEST_DIR="./artifacts/test"
LOG_DIR="./runtime/logs/current/ops"
TMP_DIR="./artifacts/test"
RECORDINGS_DIR="./runtime/recordings"
PROGRESS_FILE="./runtime/state/progress.last"
PID_FILE="./runtime/state/ffmpeg.pid"
CURRENT_LOG_FILE="./runtime/state/current_ffmpeg_log.txt"
WATCHDOG_LOCK_DIR="./runtime/state/watchdog.lock"
STREAM_LOCK_DIR="./runtime/state/stream.lock"
